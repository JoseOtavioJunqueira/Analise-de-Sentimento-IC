# Copie este arquivo para .env e preencha os valores.
# Nunca commite o arquivo .env (ele está no .gitignore).

# URI do MongoDB (opcional — se usar banco em vez de JSON)
# MONGODB_URI=mongodb://localhost:27017

# Chave da API Hugging Face (opcional — para modelos privados)
# HF_TOKEN=

# Diretório de cache do Hugging Face (opcional)
# HF_HOME=./.cache/huggingface
